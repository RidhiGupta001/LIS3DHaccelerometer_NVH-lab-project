    // Downsample
    const step = Math.max(1, Math.floor(buffer.length / MAX_DISPLAY));
    const pts  = [];
    for (let i = 0; i < buffer.length; i += step) pts.push(buffer[i]);

    // Value range with a minimum span so flat lines still show
    let mn = Infinity, mx = -Infinity;
    pts.forEach(p => { if (p[key] < mn) mn = p[key]; if (p[key] > mx) mx = p[key]; });
    const span = Math.max(mx - mn, 0.002);
    mn -= span * 0.1;
    mx += span * 0.1;

    // Time range
    const t1 = pts[0].t, t2 = pts[pts.length-1].t;
    const tSpan = Math.max(t2 - t1, 1);

    // Grid lines + Y labels
    const yTicks = 4;
    ctx.strokeStyle = '#222';
    ctx.lineWidth   = 1;
    ctx.fillStyle   = '#555';
    ctx.font        = '10px monospace';
    ctx.textAlign   = 'right';
    for (let i = 0; i <= yTicks; i++) {
      const v  = mn + (mx - mn) * (i / yTicks);
      const py = PAD.top + IH - (i / yTicks) * IH;
      ctx.beginPath();
      ctx.moveTo(PAD.left, py);
      ctx.lineTo(W - PAD.right, py);
      ctx.stroke();
      ctx.fillText(v.toFixed(4), PAD.left - 4, py + 3);
    }

    // X time labels
    ctx.textAlign = 'center';
    ctx.fillStyle = '#555';
    const xTicks = 5;
    for (let i = 0; i <= xTicks; i++) {
      const t  = t1 + tSpan * (i / xTicks);
      const px = PAD.left + (i / xTicks) * IW;
      ctx.fillText(((t)/1000).toFixed(1)+'s', px, H - 4);
    }

    // Data line
    ctx.beginPath();
    ctx.strokeStyle = color;
    ctx.lineWidth   = 1.5;
    ctx.lineJoin    = 'round';
    pts.forEach((p, i) => {
      const px = PAD.left + ((p.t - t1) / tSpan) * IW;
      const py = PAD.top  + IH - ((p[key] - mn) / (mx - mn)) * IH;
      i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
    });
    ctx.stroke();

    // Border
    ctx.strokeStyle = '#2a2a2a';
    ctx.lineWidth   = 1;
    ctx.strokeRect(PAD.left, PAD.top, IW, IH);
  }

