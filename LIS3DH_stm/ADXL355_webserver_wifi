void csLow()  { digitalWrite(CS_PIN, LOW);  }
void csHigh() { digitalWrite(CS_PIN, HIGH); }

uint8_t readRegister(uint8_t reg) {
    SPI.beginTransaction(adxl355Settings); csLow();
    SPI.transfer((reg << 1) | 0x01);
    uint8_t r = SPI.transfer(0x00);
    csHigh(); SPI.endTransaction(); return r;
}
void writeRegister(uint8_t reg, uint8_t value) {
    SPI.beginTransaction(adxl355Settings); csLow();
    SPI.transfer((reg << 1) & 0xFE); SPI.transfer(value);
    csHigh(); SPI.endTransaction();
}
void readRegisters(uint8_t startReg, uint8_t* buffer, uint8_t length) {
    SPI.beginTransaction(adxl355Settings); csLow();
    SPI.transfer((startReg << 1) | 0x01);
    for (uint8_t i = 0; i < length; i++) buffer[i] = SPI.transfer(0x00);
    csHigh(); SPI.endTransaction();
}
int32_t twosComplement20(uint32_t raw) {
    raw &= 0x000FFFFF;
    if (raw & 0x00080000) return (int32_t)(raw | 0xFFF00000);
    return (int32_t)raw;
}

struct AccelData { float x, y, z; };

AccelData readAcceleration() {
    uint8_t buf[9]; readRegisters(REG_XDATA3, buf, 9);
    AccelData data;
    data.x = twosComplement20(((uint32_t)buf[0]<<12)|((uint32_t)buf[1]<<4)|(buf[2]>>4)) * SCALE_FACTOR_2G;
    data.y = twosComplement20(((uint32_t)buf[3]<<12)|((uint32_t)buf[4]<<4)|(buf[5]>>4)) * SCALE_FACTOR_2G;
    data.z = twosComplement20(((uint32_t)buf[6]<<12)|((uint32_t)buf[7]<<4)|(buf[8]>>4)) * SCALE_FACTOR_2G;
    return data;
}

void setup() {
    Serial.begin(115200);
    delay(2000);

    // ── WiFi debug ────────────────────────────────────────────────────
    Serial.println("\n\n--- WiFi Setup ---");
    Serial.printf("Connecting to SSID: '%s'\n", SSID);

WiFi.disconnect(true);
delay(500);
WiFi.mode(WIFI_STA);
WiFi.setMinSecurity(WIFI_AUTH_WEP);   // be permissive with security type
WiFi.setSleep(false);                  // disable WiFi sleep — fixes many ESP32 drop issues
WiFi.begin(SSID, PASSWORD);

    int attempts = 0;
    while (WiFi.status() != WL_CONNECTED) {
        delay(500);
        Serial.printf("  attempt %d — status code: %d\n", ++attempts, WiFi.status());
        if (attempts >= 20) {
            Serial.println("FAILED after 20 attempts. Check SSID/password and that it's 2.4GHz.");
            Serial.println("Continuing without WiFi — sensor still works via Serial.");
            break;   // don't hang forever
        }
    }

    if (WiFi.status() == WL_CONNECTED) {
        Serial.print("Connected! Dashboard at: http://");
        Serial.println(WiFi.localIP());
        httpServer.on("/", []() {
            httpServer.send_P(200, "text/html", INDEX_HTML);
        });
        httpServer.begin();
        wsServer.begin();
    }
    // ─────────────────────────────────────────────────────────────────

    // Sensor init (unchanged)
    pinMode(CS_PIN, OUTPUT); csHigh(); delay(100);
    SPI.begin(18, 19, 23, 5);
    writeRegister(REG_RESET, 0x52); delay(100);

    uint8_t devId  = readRegister(REG_DEVID_AD);
    uint8_t mstId  = readRegister(REG_DEVID_MST);
    uint8_t partId = readRegister(REG_PARTID);
    if (devId != 0xAD || mstId != 0x1D || partId != 0xED) {
        Serial.println("ERROR: ADXL355 not found!"); while (true) delay(1000);
    }

    writeRegister(REG_RANGE,     0x01);
    writeRegister(REG_FILTER,    0x33);
    writeRegister(REG_POWER_CTL, 0x00);
    delay(100);
    Serial.println("Sensor ready.");
}

void loop() {
    httpServer.handleClient();
    wsServer.loop();

    if (readRegister(REG_STATUS) & 0x01) {
        AccelData a = readAcceleration();
        float total = sqrtf(a.x*a.x + a.y*a.y + a.z*a.z);

        char json[96];
        snprintf(json, sizeof(json),
            "{\"x\":%.6f,\"y\":%.6f,\"z\":%.6f,\"total\":%.6f}",
            a.x, a.y, a.z, total);

        wsServer.broadcastTXT(json);

        Serial.printf(">Ax:%f\n", a.x);
        Serial.printf(">Ay:%f\n", a.y);
        Serial.printf(">Az:%f\n", a.z);
        Serial.printf(">Atotal:%f\n", total);
    }
    delay(2);
}