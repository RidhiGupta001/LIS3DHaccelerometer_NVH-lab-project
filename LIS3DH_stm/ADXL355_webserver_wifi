    if (dirty) return;
    dirty = true;
    requestAnimationFrame(() => {
      dirty = false;
      drawAll();
      // Update pills
      document.getElementById('count').textContent =
        buffer.length.toLocaleString() + ' samples';
      if (buffer.length > 1) {
        const secs = ((buffer[buffer.length-1].t - buffer[0].t)/1000).toFixed(1);
