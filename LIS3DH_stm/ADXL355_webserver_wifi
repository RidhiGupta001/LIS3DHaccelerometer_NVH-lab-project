  const dataKeys = ['x','y','z','total'];

  // Set physical pixel size of each canvas
  function resizeCanvas(c) {
    const box = c.parentElement;
    c.width  = box.clientWidth - 24;   // subtract padding
    c.height = 160;
  }

  canvases.forEach(id => resizeCanvas(document.getElementById(id)));
  window.addEventListener('resize', () => {
    canvases.forEach(id => {
      resizeCanvas(document.getElementById(id));
    });
